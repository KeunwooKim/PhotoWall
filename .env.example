# Supabase (optional — 없으면 링크 인코딩 방식으로 공유)
# Supabase Dashboard → Project Settings → API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth — Google Cloud Console 값은 Supabase Dashboard → Authentication → Providers → Google 에 입력

# ── Supabase SQL (순서대로 1회 실행) ──
# 1. supabase/schema.sql
# 2. supabase/auth-migration.sql
# 3. supabase/storage-migration.sql
# 4. supabase/social-migration.sql
# 5. supabase/shared-walls-migration.sql
# 6. supabase/privacy-invites-migration.sql
# 7. supabase/security-hardening-migration.sql
# 8. supabase/admin-inquiries-migration.sql
# 9. supabase/admin-rls-migration.sql
#    → insert into app_admins (user_id) values ('YOUR-UUID');
# 10. supabase/storage-private-migration.sql   ← 앱 배포 후 실행 (private Storage)
# 11. supabase/walls-select-rls-migration.sql  ← walls SELECT RLS 강화

# ── Admin (서버 전용 — Vercel Production, .env.local) ──
# Supabase Dashboard → Authentication → Users 에서 본인 UUID 확인
ADMIN_USER_IDS=your-supabase-user-uuid
# Supabase Dashboard → Project Settings → API → service_role (클라이언트 노출 금지)
# 공동벽·친구 벽 사진 signed URL 발급에 필요 (없으면 본인 사진만 미리보기 가능)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Google 로그인 (프로덕션) 설정 체크리스트 ──
#
# 1) Supabase → Authentication → URL Configuration  ★ 가장 중요
#    Site URL:        https://photowall-one.vercel.app   ← localhost면 프로덕션 로그인 후 localhost로 감
#    Redirect URLs:
#      http://localhost:3000/auth/callback
#      https://photowall-one.vercel.app/auth/callback
#
# 2) Supabase → Authentication → Providers → Google (Enabled)
#    Client ID / Secret: Google Cloud Console OAuth 2.0 클라이언트 값
#
# 3) Google Cloud Console → API 및 서비스 → 사용자 인증 정보 → OAuth 2.0 클라이언트
#    승인된 JavaScript 원본:
#      http://localhost:3000
#      https://photowall-one.vercel.app
#    승인된 리디렉션 URI (Supabase callback만 — 앱 URL 아님):
#      https://YOUR-PROJECT.supabase.co/auth/v1/callback
#
# 4) Vercel → Settings → Environment Variables (Production + Preview)
#    NEXT_PUBLIC_SUPABASE_URL
#    NEXT_PUBLIC_SUPABASE_ANON_KEY
#    ADMIN_USER_IDS
#    SUPABASE_SERVICE_ROLE_KEY
