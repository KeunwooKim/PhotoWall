# Supabase (optional — 없으면 링크 인코딩 방식으로 공유)
# Supabase Dashboard → Project Settings → API 에서 복사
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Google OAuth — Google Cloud Console 값은 Supabase Dashboard에 입력 (앱 .env에는 불필요)

# ── Supabase SQL (순서대로 1회 실행) ──
# 1. supabase/schema.sql
# 2. supabase/auth-migration.sql
# 3. supabase/storage-migration.sql
# 4. supabase/social-migration.sql
# 5. supabase/shared-walls-migration.sql

# ── Vercel 배포 후 URL 등록 ──
# Supabase → Authentication → URL Configuration:
#   Site URL: https://YOUR-APP.vercel.app
#   Redirect URLs:
#     http://localhost:3000/auth/callback
#     https://YOUR-APP.vercel.app/auth/callback
#
# Google Cloud → OAuth 클라이언트 → 승인된 리디렉션 URI:
#   https://YOUR-PROJECT.supabase.co/auth/v1/callback  (Supabase용, 기존 유지)
#
# Vercel → Settings → Environment Variables:
#   NEXT_PUBLIC_SUPABASE_URL
#   NEXT_PUBLIC_SUPABASE_ANON_KEY
